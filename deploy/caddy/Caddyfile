# HTTPS na :8443 (443 zajęte przez UI TrueNAS). Cert Let's Encrypt dla summa.cyplos.pl
# przez Cloudflare DNS-01 (token w env CF_API_TOKEN). Nie wymaga wystawiania portów na
# świat — challenge idzie przez DNS. DNS A → REDACTED-HOST (Tailscale IP drukpola);
# dostęp z tailnetu. Cert niezależny od Tailscale (to tylko trasa sieciowa).
{
	# Nie zarządzamy portem 80 (ma go nginx TrueNAS) — bez przekierowań HTTP→HTTPS.
	auto_https disable_redirects
	email wysocki733@gmail.com
}

summa.cyplos.pl:8443 {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1
	}
	reverse_proxy summa-cut-web:8000
}
